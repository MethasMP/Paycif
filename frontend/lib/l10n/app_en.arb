  "privacyHighlightsTitle": "Privacy at a Glance",
  "privacyHighlight1": "We never sell your personal data to third parties",
  "privacyHighlight2": "Your payment data is encrypted end-to-end",
  "privacyHighlight3": "You can request deletion of your data at any time",
